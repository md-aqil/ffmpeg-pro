ation':\n        return `${(activeOperation.value ?? 1).toFixed(1)}`;\n      case 'effect':\n        return activeOperation.effect || 'blur';\n      case 'watermark':\n        return `${activeOperation.position || 'bottom-right'}, ${activeOperation.opacity ?? 50}%`;\n      case 'optimize':\n        return `${activeOperation.quality || 80}% quality`;\n      default:\n        return activeOperation.type;\n    }\n  })", "source_file": "/Users/mdaqil/Documents/ffmpeg-pro/client/src/pages/StudioPage.js", "source_location": "L255"}, {"caller_nid": "studiopage_studiopage", "callee": "round", "source_file": "/Users/mdaqil/Documents/ffmpeg-pro/client/src/pages/StudioPage.js", "source_location": "L281"}, {"caller_nid": "studiopage_studiopage", "callee": "map", "source_file": "/Users/mdaqil/Documents/ffmpeg-pro/client/src/pages/StudioPage.js", "source_location": "L344"}, {"caller_nid": "studiopage_studiopage", "callee": "map", "source_file": "/Users/mdaqil/Documents/ffmpeg-pro/client/src/pages/StudioPage.js", "source_location": "L647"}, {"caller_nid": "studiopage_studiopage", "callee": "map", "source_file": "/Users/mdaqil/Documents/ffmpeg-pro/client/src/pages/StudioPage.js", "source_location": "L682"}, {"caller_nid": "studiopage_studiopage", "callee": "map", "source_file": "/Users/mdaqil/Documents/ffmpeg-pro/client/src/pages/StudioPage.js", "source_location": "L762"}]}